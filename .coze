[project]
sub_id = "b0e03ed5"
name = "magic-web-ui"
requires = ["nodejs-24"]
project_type = "web"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "scripts/coze-preview-build.sh"]
run = ["bash", "scripts/coze-preview-run.sh"]

[subprojects]
path = ["."]

[deploy]
build = ["pnpm", "run", "build"]
run = ["bash", "scripts/coze-deploy-run.sh"]

[deploy.profile]
kind = "service"
flavor = "web"
